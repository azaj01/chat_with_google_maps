{
  "name": "copy-of-chat-with-maps-live",
  "private": true,
  "version": "0.0.27",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "quality": "npm run typecheck && npm run lint && npm run format:check && npm run test",
    "prepare": "husky",
    "api:dev": "tsx watch api/_server.ts",
    "api:start": "tsx api/_adapters/node.ts",
    "docker:build": "docker build -t chat-with-maps-api .",
    "docker:run": "docker run -p 3011:3011 --env-file .env chat-with-maps-api",
    "dev:all": "concurrently \"npm run api:dev\" \"npm run dev\"",
    "db:start": "docker compose up -d db",
    "db:stop": "docker compose stop db",
    "db:reset": "docker compose down db -v && docker compose up -d db",
    "db:logs": "docker compose logs -f db",
    "db:shell": "docker compose exec db psql -U ${POSTGRES_USER:-chatmaps} -d ${POSTGRES_DB:-chatmaps}",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "langfuse:start": "docker compose up -d langfuse-server langfuse-db",
    "langfuse:stop": "docker compose stop langfuse-server langfuse-db",
    "langfuse:logs": "docker compose logs -f langfuse-server",
    "langfuse:reset": "docker compose down langfuse-server langfuse-db -v && docker compose up -d langfuse-server langfuse-db"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,html}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@hono/node-server": "^2.0.3",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@vis.gl/react-google-maps": "^1.8.3",
    "better-auth": "^1.6.11",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "eventemitter3": "^5.0.4",
    "fast-deep-equal": "^3.1.3",
    "framer-motion": "^12.39.0",
    "hono": "^4.12.21",
    "langfuse": "^3.38.20",
    "lodash": "^4.18.1",
    "lucide-react": "^1.16.0",
    "next-themes": "^0.4.6",
    "nuqs": "^2.8.9",
    "path": "^0.12.7",
    "pino": "^10.3.1",
    "postgres": "^3.4.9",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.15.1",
    "remark-gfm": "^4.0.0",
    "rotating-file-stream": "^3.2.9",
    "tailwind-merge": "^3.6.0",
    "vite": "^8.0.13",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "overrides": {
    "esbuild": "^0.25.0",
    "path-to-regexp": "^8.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/postcss": "^4.3.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/lodash": "^4.17.24",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vercel/node": "^5.8.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.6",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.5",
    "pino-pretty": "^13.1.3",
    "postcss": "^8.5.6",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4",
    "vite": "^8.0.13",
    "vitest": "^4.1.6"
  }
}
